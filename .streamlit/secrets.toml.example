# Copy to `secrets.toml` in this folder to override built-in login defaults.
# Built-in defaults: username admin, password RO_760715 (see core/auth.py).
#
# Optional overrides:
# login_username = "myuser"
# login_password = "strong-secret"
#
# Or nested:
# [auth]
# login_username = "myuser"
# login_password = "strong-secret"
#
# Disable the login gate entirely (local dev / CI):
# Set environment variable VACCINE_APP_NO_AUTH=1
